generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id               String         @id @default(cuid())
  nombre           String
  usuario          String         @unique
  passwordHash     String
  rol              RolUsuario     @default(VENDEDOR)
  intentosFallidos Int            @default(0)
  bloqueadoHasta   DateTime?
  cierresCaja      CierreCaja[]
  logsAuditoria    LogAuditoria[]
  transacciones    Transaccion[]

  @@map("usuarios")
}

model Categoria {
  id        String        @id @default(cuid())
  nombre    String        @unique
  tipo      TipoCategoria @default(normal)
  productos Producto[]

  @@map("categorias")
}

model Producto {
  id          String    @id @default(cuid())
  nombre      String    @unique
  categoriaId String
  precio      Decimal   @db.Decimal(10, 2)
  costo       Decimal   @db.Decimal(10, 2)
  stock       Int       @default(0)
  esDePaquete Boolean   @default(false)
  categoria   Categoria @relation(fields: [categoriaId], references: [id])
  ventas      Venta[]

  @@map("productos")
}

model Transaccion {
  id              String   @id @default(cuid())
  fecha           DateTime @default(now())
  vendedorId      String
  total           Decimal  @db.Decimal(10, 2)
  pagoEfectivo    Decimal  @default(0) @db.Decimal(10, 2)
  pagoNequi       Decimal  @default(0) @db.Decimal(10, 2)
  pagoBancolombia Decimal  @default(0) @db.Decimal(10, 2)
  pagoFiado       Decimal  @default(0) @db.Decimal(10, 2)
  fiado           Fiado?
  vendedor        Usuario  @relation(fields: [vendedorId], references: [id])
  ventas          Venta[]

  @@index([fecha])
  @@index([vendedorId])
  @@map("transacciones")
}

model Venta {
  id             String      @id @default(cuid())
  productoId     String
  transaccionId  String
  cantidad       Int
  precioUnitario Decimal     @db.Decimal(10, 2)
  total          Decimal     @db.Decimal(10, 2)
  fecha          DateTime    @default(now())
  producto       Producto    @relation(fields: [productoId], references: [id])
  transaccion    Transaccion @relation(fields: [transaccionId], references: [id])

  @@index([fecha])
  @@index([productoId])
  @@index([transaccionId])
  @@map("ventas")
}

model Cliente {
  id            String   @id @default(cuid())
  nombre        String   @unique
  telefono      String?
  fechaRegistro DateTime @default(now())
  fiados        Fiado[]

  @@map("clientes")
}

model Fiado {
  id                 String      @id @default(cuid())
  clienteId          String
  transaccionId      String      @unique
  montoTotal         Decimal     @db.Decimal(10, 2)
  montoPagado        Decimal     @default(0) @db.Decimal(10, 2)
  estado             EstadoFiado @default(PENDIENTE)
  fechaCreacion      DateTime    @default(now())
  fechaActualizacion DateTime    @updatedAt
  notas              String?
  cliente            Cliente     @relation(fields: [clienteId], references: [id])
  transaccion        Transaccion @relation(fields: [transaccionId], references: [id])

  @@index([estado])
  @@index([clienteId])
  @@map("fiados")
}

model LogAuditoria {
  id        String   @id @default(cuid())
  usuarioId String
  accion    String
  fecha     DateTime @default(now())
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])

  @@index([fecha])
  @@index([usuarioId])
  @@map("logs_auditoria")
}

model CierreCaja {
  id                  String   @id @default(cuid())
  fecha               DateTime @default(now())
  totalVentas         Decimal  @db.Decimal(10, 2)
  numeroTransacciones Int
  totalEfectivo       Decimal  @default(0) @db.Decimal(10, 2)
  totalNequi          Decimal  @default(0) @db.Decimal(10, 2)
  totalBancolombia    Decimal  @default(0) @db.Decimal(10, 2)
  totalFiado          Decimal  @default(0) @db.Decimal(10, 2)
  usuarioId           String
  usuario             Usuario  @relation(fields: [usuarioId], references: [id])

  @@map("cierres_caja")
}

enum RolUsuario {
  ADMIN
  VENDEDOR
}

enum TipoCategoria {
  normal
  sensible
}

enum EstadoFiado {
  PENDIENTE
  PAGADO_PARCIAL
  PAGADO_TOTAL
}
